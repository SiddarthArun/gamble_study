{
  "manifest_version": 3,
  "name": "StudyBet",
  "version": "1.0.0",
  "description": "Gamified high-volatility Pomodoro timer and task manager",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "declarativeNetRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["casino.png", "alarm.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}
