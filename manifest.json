{
  "manifest_version": 3,
  "name": "StudyRoulette",
  "version": "1.0.0",
  "description": "Gamified high-volatility Pomodoro timer and task manager",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["casino.png"],
      "matches": ["<all_urls>"]
    }
  ]
}